frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Production/Distribution builds
frontend/build/
frontend/dist/

# Next.js telemetry/cache
frontend/.next/cache/

# Cypress/Testing
frontend/cypress/screenshots/
frontend/cypress/videos/

# ------------------------------------------------------------------------------
# Python Backend / LangChain
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class

# C extensions
*.so

